{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HCS-26 Skill Registry Schema",
  "description": "Schema for HCS-26 compatible agent skill manifest",
  "type": "object",
  "required": ["skill-id", "name", "description", "category", "tags", "compatible-with"],
  "properties": {
    "skill-id": { "type": "string", "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+$" },
    "name": { "type": "string", "minLength": 2 },
    "description": { "type": "string", "minLength": 20 },
    "category": {
      "type": "string",
      "enum": ["coding", "research", "writing", "data", "devops", "security", "testing", "documentation", "communication", "other"]
    },
    "tags": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 10 },
    "compatible-with": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "schema-version": { "type": "string" },
    "license": { "type": "string" }
  }
}
